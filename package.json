  },
  "dependencies": {
    "@raycast/api": "^1.83.2"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "^22.10.2",
    "eslint": "^8.57.1",
    "prettier": "^3.8.3",
    "typescript": "5.3.3"
  }
