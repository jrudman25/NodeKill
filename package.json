{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "nodekill",
  "title": "NodeKill",
  "description": "Find and stop localhost development servers on Windows.",
  "icon": "extension-icon.png",
  "version": "0.2.0",
